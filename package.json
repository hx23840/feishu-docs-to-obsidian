{
  "name": "feishu-obsidian-importer",
  "version": "0.1.0",
  "description": "Import Feishu/Lark documents into an Obsidian vault with local images.",
  "main": "main.js",
  "private": false,
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "feishu",
    "lark",
    "markdown",
    "importer"
  ],
  "author": "VibeCoding",
  "license": "MIT",
  "files": [
    "main.js",
    "manifest.json",
    "styles.css"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.1",
    "obsidian": "^1.8.7",
    "typescript": "^5.5.4"
  }
}
